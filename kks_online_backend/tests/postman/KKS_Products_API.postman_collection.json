									"key": "pageSize",
									"value": "20",
									"description": "Number of items per page"
								},
								{
									"key": "isPopular",
									"value": "true",
									"description": "Filter by popular products",
									"disabled": true
								},
								{
									"key": "q",
									"value": "",
									"description": "Search query",
									"disabled": true
								},
								{
									"key": "categoryId",
									"value": "",
									"description": "Filter by category ID",
									"disabled": true
								},
								{
									"key": "brandId",
									"value": "",
									"description": "Filter by brand ID",
									"disabled": true
								},
								{
									"key": "minPrice",
									"value": "",
									"description": "Minimum price filter",
									"disabled": true
								},
								{
									"key": "maxPrice",
									"value": "",
									"description": "Maximum price filter",
									"disabled": true
								},
								{
									"key": "tag",
									"value": "",
									"description": "Filter by tag",
									"disabled": true
								},
								{
									"key": "sortBy",
									"value": "name",
									"description": "Sort field: name, price, created_at, popularity",
									"disabled": true
								},
								{
									"key": "sortOrder",
									"value": "asc",
									"description": "Sort order: asc, desc",
									"disabled": true
								}
							]
						},
						"description": "Get products with optional filters and pagination.\n\n**Query Parameters:**\n- `page` (optional): Page number, defaults to 1\n- `pageSize` (optional): Items per page, defaults to 20\n- `q` (optional): Search query\n- `categoryId` (optional): Filter by category\n- `brandId` (optional): Filter by brand\n- `minPrice` (optional): Minimum price\n- `maxPrice` (optional): Maximum price\n- `isPopular` (optional): Filter popular products (true/false)\n- `tag` (optional): Filter by tag\n- `sortBy` (optional): Sort field (name, price, created_at, popularity)\n- `sortOrder` (optional): Sort order (asc, desc)"
					},
					"response": []
				},
